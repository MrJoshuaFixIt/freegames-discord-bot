# .env.example
# Copy this file to .env and fill in your values.
# On Railway, set these as environment variables in your project settings.

# ── REQUIRED ────────────────────────────────────────────────────────────────

# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# Your Discord application/client ID
DISCORD_CLIENT_ID=your_discord_application_id_here

# The Discord channel ID where free game announcements will be posted
# Right-click any channel → "Copy Channel ID" (enable Developer Mode first)
CHANNEL_ID=your_discord_channel_id_here

# ── OPTIONAL ─────────────────────────────────────────────────────────────────

# RAWG.io API key for game ratings + multiplayer info (free at https://rawg.io/apidocs)
# Without this, ratings will show as "No rating found"
RAWG_API_KEY=your_rawg_api_key_here

# Discord role ID to ping when new free games are posted
# Leave blank to post without any role mention
# Right-click a role → "Copy Role ID"
NOTIFY_ROLE_ID=

# Railway volume mount path for persistent SQLite storage
# Railway sets this automatically when you attach a volume
# RAILWAY_VOLUME_MOUNT_PATH=/data
